{
  "name": "ntfy-mac",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "start": "bun src/index.ts",
    "setup": "bun src/index.ts setup",
    "build:helper": "bash scripts/build-helper.sh",
    "build:bun": "bun build --compile --target=bun-darwin-arm64 src/index.ts --outfile dist/ntfy-mac --define APP_VERSION='\"$npm_package_version\"'",
    "build:package-helper": "mkdir -p dist && tar -czf dist/ntfy-notify.app.tar.gz -C assets ntfy-notify.app",
    "build": "bun run build:helper && bun run build:bun && bun run build:package-helper",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "lint": "find src -name '*.ts' | xargs bunx oxlint",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "validate": "bun run format:check && bun run typecheck && bun run lint && bun run test",
    "generate:emojis": "bun scripts/generate-emojis.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "latest",
    "@semantic-release/git": "latest",
    "@semantic-release/github": "latest",
    "@types/bun": "latest",
    "lefthook": "^2.1.4",
    "oxlint": "latest",
    "prettier": "latest",
    "semantic-release": "latest"
  },
  "release": {
    "branches": [
      "master"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md"
          ],
          "message": "chore(release): ${nextRelease.version}"
        }
      ]
    ]
  }
}
